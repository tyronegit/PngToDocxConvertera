<Window x:Class="PngToDocxConvertera.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image to DOCX Converter Pro"
        Height="720"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5568"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A0AEC0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="#4AA5FF"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2D3748"/>
                    <Setter Property="Foreground" Value="#4AA5FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D3748"/>
                    <Setter Property="Foreground" Value="#4AA5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="PanelSectionHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4AA5FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PanelSectionBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#2D3748"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#181818"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu x:Name="MainMenu"
              DockPanel.Dock="Top"
              Background="#121212"
              Foreground="#4AA5FF"> 

            <MenuItem Header="_File">
                <MenuItem Header="_Open Image..."
                  InputGestureText="Ctrl+O"
                  Click="MenuOpen_Click"/>
                <MenuItem Header="_Save Word Document..."
                  InputGestureText="Ctrl+S"
                  Click="MenuSaveAs_Click"/>
                <Separator/>
                <MenuItem Header="E_xit"
                  Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="Clear Workspace"
                  Click="ClearWorkspaceMenuItem_Click"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_User Guide"
                  Click="MenuUserGuide_Click"/>
                <MenuItem Header="_About"
                  Click="MenuAbout_Click"/>
            </MenuItem>

        </Menu>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock x:Name="TitleTextBlock"
                               Text="Image to DOCX Converter Pro"
                               FontSize="24"
                               FontWeight="Bold" />

                <TextBlock x:Name="SubtitleTextBlock"
                               Text="Offline batch OCR for DOCX, TXT, and searchable PDF exports" />
                            </StackPanel>   

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Image Preview" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>

                        <Border Grid.Row="1" Background="#121212" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4" Margin="0,0,0,15">
                            <Grid>
                                <TextBlock x:Name="DropHintText" Text="Drag Image Here" Foreground="#4A5568" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                <Image x:Name="PreviewImage" Margin="5" Stretch="Uniform"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource PanelSectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Input" Style="{StaticResource PanelSectionHeaderText}"/>
                                        <TextBlock Text="Selected File:" Foreground="#A0AEC0" FontWeight="SemiBold" Margin="0,0,4,4"/>
                                        <TextBox x:Name="SelectedFileTextBox" IsReadOnly="True" Background="#121212" Foreground="#A0AEC0" BorderBrush="#2D3748" Padding="5" Margin="0,0,0,10" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Disabled"/>
                                        <Button x:Name="SelectImageButton" Content="Select Image File" Click="SelectImageButton_Click" Margin="0"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelSectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="OCR Settings" Style="{StaticResource PanelSectionHeaderText}"/>
                                        <TextBlock Text="OCR Language on Image:" Foreground="#A0AEC0" FontWeight="SemiBold" Margin="0,0,4,4"/>
                                        <ComboBox x:Name="OcrLanguageComboBox"
                                                  SelectedIndex="0"
                                                  Background="#121212"
                                                  Foreground="#4AA5FF"
                                                  BorderBrush="#2D3748"
                                                  Padding="5"
                                                  FontWeight="SemiBold"
                                                  Margin="0,0,0,10"/>
                                        <TextBlock Text="This recognizes text; it does not translate."
                                                   Foreground="#A0AEC0"
                                                   FontSize="11"
                                                   Margin="0,-6,0,8"/>
                                        <CheckBox x:Name="AutoFixCheckBox" Content="Auto-fix image for OCR" IsChecked="True" Margin="0"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelSectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Export Options" Style="{StaticResource PanelSectionHeaderText}"/>
                                        <CheckBox x:Name="SearchablePdfCheckBox" Content="Create searchable image PDFs" IsChecked="True"/>
                                        <CheckBox x:Name="CombinePdfCheckBox" Content="Combine batch PDFs into one file" IsChecked="False" Margin="0"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelSectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Single File" Style="{StaticResource PanelSectionHeaderText}"/>
                                        <Button x:Name="PreviewOcrButton" Content="Preview OCR" Click="PreviewOcrButton_Click"/>
                                        <Button x:Name="ConvertSingleButton" Content="Save Word to Folder" Click="ConvertButton_Click"/>
                                        <Button x:Name="SaveTxtButton" Content="Save TXT to Folder" Click="SaveTxtButton_Click"/>
                                        <Button x:Name="SavePdfButton" Content="Save PDF to Folder" Click="SavePdfButton_Click" Margin="0"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource PanelSectionBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Batch Conversion" Style="{StaticResource PanelSectionHeaderText}"/>
                                        <CheckBox x:Name="AskOutputFolderCheckBox" Content="Choose output folder for batches" IsChecked="False"/>
                                        <CheckBox x:Name="IncludeSubfoldersCheckBox" Content="Include subfolders in batch" IsChecked="False"/>
                                        <Button x:Name="BatchDocxButton" Content="Convert Image Folder to DOCX" Click="BatchDocxButton_Click"/>
                                        <Button x:Name="BatchTxtButton" Content="Convert Image Folder to TXT" Click="BatchTxtButton_Click"/>
                                        <Button x:Name="BatchPdfButton" Content="Convert Image Folder to PDF" Click="BatchPdfButton_Click"/>
                                        <Button x:Name="CancelBatchButton" Content="Cancel Batch" Click="CancelBatchButton_Click" IsEnabled="False" Visibility="Collapsed" Margin="0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="OCR Preview - Edit before saving:" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>

                        <TextBox x:Name="OcrPreviewTextBox" 
                                 Grid.Row="1" 
                                 AcceptsReturn="True" 
                                 AcceptsTab="True" 
                                 TextWrapping="Wrap" 
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#121212" 
                                 Foreground="#FFFFFF" 
                                 BorderBrush="#2D3748" 
                                 Padding="10" 
                                 FontSize="14"
                                 CaretBrush="#FFFFFF"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Padding="10,8" Margin="0,15,0,0" BorderBrush="#2D2D2D" BorderThickness="1" MinHeight="58">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Status:"
                               Foreground="#4AA5FF"
                               FontWeight="SemiBold"
                               FontSize="12"/>

                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Row="0"
                               Grid.Column="1"
                               Text="Ready"
                               Foreground="#A0AEC0"
                               FontSize="12"/>

                    <TextBlock x:Name="BatchCounterTextBlock"
                               Grid.Row="0"
                               Grid.Column="2"
                               Text="Batch: idle"
                               Foreground="#A0AEC0"
                               FontSize="12"
                               HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Progress:"
                               Foreground="#4AA5FF"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="0,8,8,0"/>

                    <ProgressBar x:Name="BatchProgressBar"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Height="18"
                                 Background="#0B1220"
                                 Foreground="#4AA5FF"
                                 BorderBrush="#4A5568"
                                 BorderThickness="1"
                                 Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
