<Window x:Class="PngToDocxConvertera.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image to DOCX Converter"
        Height="720"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5568"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A0AEC0"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu x:Name="MainMenu"
              DockPanel.Dock="Top"
              Background="#121212"
              Foreground="#4AA5FF"> 

            <MenuItem Header="_File">
                <MenuItem Header="_Open Image..."
                  InputGestureText="Ctrl+O"
                  Click="MenuOpen_Click"/>
                <MenuItem Header="_Save Document As..."
                  InputGestureText="Ctrl+S"
                  Click="MenuSaveAs_Click"/>
                <Separator/>
                <MenuItem Header="E_xit"
                  Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="Clear Workspace"
                  Click="ClearWorkspaceMenuItem_Click"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About"
                  Click="MenuAbout_Click"/>
            </MenuItem>

        </Menu>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock x:Name="TitleTextBlock"
                               Text="Image to DOCX Converter"
                               FontSize="24"
                               FontWeight="Bold" />

                <TextBlock x:Name="SubtitleTextBlock"
                               Text="Convert PNG, JPG, BMP and TIFF images into editable Word documents" />
                            </StackPanel>   

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Image Preview" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>

                        <Border Grid.Row="1" Background="#121212" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="4" Margin="0,0,0,15">
                            <Grid>
                                <TextBlock x:Name="DropHintText" Text="Drag Image Here" Foreground="#4A5568" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                <Image x:Name="PreviewImage" Margin="5" Stretch="Uniform"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Selected File:" Foreground="#A0AEC0" FontWeight="SemiBold" Margin="0,0,4,4"/>
                            <TextBox x:Name="SelectedFileTextBox" IsReadOnly="True" Background="#121212" Foreground="#A0AEC0" BorderBrush="#2D3748" Padding="5" Margin="0,0,0,12" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Disabled"/>

                            <CheckBox x:Name="AutoFixCheckBox" Content="Auto-fix image for OCR" IsChecked="True"/>

                            <Button x:Name="SelectImageButton" Content="Select Image File" Click="SelectImageButton_Click"/>
                            <Button x:Name="PreviewOcrButton" Content="Preview OCR" Click="PreviewOcrButton_Click"/>

                            <Button x:Name="ConvertSingleButton" Content="Convert to Word Document" Click="ConvertButton_Click"/>

                            <Button x:Name="SaveTxtButton" Content="Save as TXT" Click="SaveTxtButton_Click"/>

                            <Button x:Name="SavePdfButton" Content="Save as PDF" Click="SavePdfButton_Click"/>

                            <Button x:Name="BatchConvertButton" Content="Convert Multiple Image Files" Click="BatchConvertButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="OCR Preview - Edit before saving:" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>

                        <TextBox x:Name="OcrPreviewTextBox" 
                                 Grid.Row="1" 
                                 AcceptsReturn="True" 
                                 AcceptsTab="True" 
                                 TextWrapping="Wrap" 
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#121212" 
                                 Foreground="#FFFFFF" 
                                 BorderBrush="#2D3748" 
                                 Padding="10" 
                                 FontSize="14"
                                 CaretBrush="#FFFFFF"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Padding="8,6" Margin="0,15,0,0" BorderBrush="#2D2D2D" BorderThickness="1">
                <TextBlock x:Name="StatusTextBlock" Text="Ready" Foreground="#A0AEC0" FontSize="12"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>